{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/git puhtml/index.html" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/images/(.*)", "destination": "/images/$1" },
    { "source": "/admin/(.*)", "destination": "/admin/$1" },
    { "source": "/backend/(.*)", "destination": "/backend/$1" },
    { "source": "/(.*)", "destination": "/html/$1" }
  ]
}